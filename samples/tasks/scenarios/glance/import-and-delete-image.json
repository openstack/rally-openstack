{
    "version": 2,
    "title": "Import and delete Glance images using different import methods",
    "description": "Test the Glance v2 interoperable image import workflow",
    "subtasks": [
        {
            "title": "Import and delete using glance-direct method",
            "scenario": {
                "GlanceImages.import_and_delete_image": {
                    "image_location": "http://download.cirros-cloud.net/0.5.2/cirros-0.5.2-x86_64-disk.img",
                    "container_format": "bare",
                    "disk_format": "qcow2",
                    "visibility": "private",
                    "min_disk": 0,
                    "min_ram": 64,
                    "properties": {
                        "hw_disk_bus": "scsi",
                        "hw_scsi_model": "virtio-scsi",
                        "os_type": "linux"
                    },
                    "import_method": "glance-direct",
                    "stores": null,
                    "all_stores": true
                }
            },
            "runner": {
                "constant": {
                    "times": 10,
                    "concurrency": 2
                }
            },
            "contexts": {
                "users": {
                    "tenants": 2,
                    "users_per_tenant": 1
                }
            },
            "sla": {
                "max_seconds_per_iteration": 120,
                "max_avg_duration": 60,
                "failure_rate": {
                    "max": 0
                }
            }
        },
        {
            "title": "Import and delete using web-download method",
            "description": "Test with qcow2 format and web-download method",
            "scenario": {
                "GlanceImages.import_and_delete_image": {
                    "image_location": "http://download.cirros-cloud.net/0.5.2/cirros-0.5.2-x86_64-disk.img",
                    "container_format": "bare",
                    "disk_format": "qcow2",
                    "import_method": "web-download",
                    "all_stores": true
                }
            },
            "runner": {
                "constant": {
                    "times": 5,
                    "concurrency": 1
                }
            },
            "contexts": {
                "users": {
                    "tenants": 1,
                    "users_per_tenant": 1
                }
            },
            "sla": {
                "max_seconds_per_iteration": 120,
                "failure_rate": {
                    "max": 0
                }
            }
        },
        {
            "title": "Import and delete with specific properties",
            "scenario": {
                "GlanceImages.import_and_delete_image": {
                    "image_location": "http://download.cirros-cloud.net/0.5.2/cirros-0.5.2-x86_64-disk.img",
                    "container_format": "bare",
                    "disk_format": "qcow2",
                    "visibility": "private",
                    "min_disk": 1,
                    "min_ram": 128,
                    "properties": {
                        "os_distro": "cirros",
                        "os_version": "0.5.2",
                        "architecture": "x86_64",
                        "hypervisor_type": "qemu"
                    },
                    "all_stores": true
                }
            },
            "runner": {
                "constant": {
                    "times": 5,
                    "concurrency": 1
                }
            },
            "contexts": {
                "users": {
                    "tenants": 1,
                    "users_per_tenant": 1
                }
            },
            "sla": {
                "failure_rate": {
                    "max": 0
                }
            }
        },
        {
            "title": "Import stress test - high concurrency",
            "scenario": {
                "GlanceImages.import_and_delete_image": {
                    "image_location": "http://download.cirros-cloud.net/0.5.2/cirros-0.5.2-x86_64-disk.img",
                    "container_format": "bare",
                    "disk_format": "qcow2",
                    "visibility": "private",
                    "all_stores": true
                }
            },
            "runner": {
                "constant": {
                    "times": 20,
                    "concurrency": 5
                }
            },
            "contexts": {
                "users": {
                    "tenants": 3,
                    "users_per_tenant": 2
                }
            },
            "sla": {
                "max_seconds_per_iteration": 180,
                "failure_rate": {
                    "max": 5
                }
            }
        },
        {
            "title": "Import with multistore - specific stores",
            "description": "For multistore deployments, import to specific backend stores.",
            "scenario": {
                "GlanceImages.import_and_delete_image": {
                    "image_location": "http://download.cirros-cloud.net/0.5.2/cirros-0.5.2-x86_64-disk.img",
                    "container_format": "bare",
                    "disk_format": "qcow2",
                    "visibility": "private",
                    "stores": null,
                    "all_stores": true
                }
            },
            "runner": {
                "constant": {
                    "times": 3,
                    "concurrency": 1
                }
            },
            "contexts": {
                "users": {
                    "tenants": 1,
                    "users_per_tenant": 1
                }
            },
            "sla": {
                "failure_rate": {
                    "max": 0
                }
            }
        }
    ]
}
